{{#if peopleWithUpcomingBirthdays}}

<h4>{{p 'celebrations.title'}}</h4>

<div class="row">
  {{#each peopleWithUpcomingBirthdays}}
    <div class="col s12 m6 l4">
      <span class="left new badge">{{readableDayMonth nextBirthday}}</span>
      {{firstName}} {{lastName}}{{p 'celebrations.turning' nextAge}}
    </div>
  {{/each}}
</div>

{{/if}}